# Environment Configuration Example
# Copy this to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True
API_RELOAD=True

# Database Configuration
DATABASE_URL=postgresql://labuser:labpass@localhost:5432/production_systems_lab

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# External APIs (if used)
EXTERNAL_API_KEY=your_key_here

# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
